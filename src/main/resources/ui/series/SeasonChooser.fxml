<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.*?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
           fx:controller="com.esprit.controllers.series.SeasonChooserController"
           styleClass="immersive-root"
           stylesheets="@../styles/rakcha-unified.css">

  <!-- Cinematic Background -->
  <AnchorPane fx:id="cinematicBackground" styleClass="cinematic-bg">
    <Circle radius="250" layoutX="100" layoutY="200" styleClass="ambient-orb orb-primary" opacity="0.2"/>
    <Circle radius="350" layoutX="1300" layoutY="700" styleClass="ambient-orb orb-secondary" opacity="0.15"/>
    <Circle radius="180" layoutX="900" layoutY="50" styleClass="ambient-orb orb-accent" opacity="0.18"/>
  </AnchorPane>

  <!-- Main Application Shell -->
  <BorderPane styleClass="main-shell">
    <left>
      <fx:include source="../sidebar.fxml"/>
    </left>

    <center>
      <ScrollPane fitToWidth="true" styleClass="scroll-pane-transparent" hbarPolicy="NEVER">
        <VBox spacing="25" style="-fx-background-color: transparent;">
          <padding>
            <Insets top="30" right="40" bottom="40" left="40"/>
          </padding>

          <!-- Hero Section -->
          <VBox fx:id="heroSection" styleClass="hero-section-glass" spacing="15">
            <padding>
              <Insets top="30" right="35" bottom="35" left="35"/>
            </padding>

            <HBox spacing="25" alignment="TOP_LEFT">
              <!-- Series Poster -->
              <VBox alignment="TOP_CENTER">
                <ImageView fx:id="seriesPosterImage" fitHeight="280" fitWidth="190" preserveRatio="true">
                  <effect>
                    <DropShadow color="#00000066" radius="20" spread="0.1"/>
                  </effect>
                </ImageView>
              </VBox>

              <!-- Series Info -->
              <VBox spacing="12" HBox.hgrow="ALWAYS">
                <!-- Title Row -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                  <Button onAction="#goBack" styleClass="back-btn-glass">
                    <graphic>
                      <FontIcon iconLiteral="mdi2a-arrow-left:20"/>
                    </graphic>
                  </Button>
                  <Label fx:id="seriesTitleLabel" text="Series Title" styleClass="hero-title" wrapText="true">
                    <font>
                      <Font name="Arial Rounded MT Bold" size="32.0"/>
                    </font>
                  </Label>
                </HBox>

                <!-- Meta Info -->
                <HBox spacing="20" styleClass="meta-row">
                  <HBox spacing="8" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="mdi2c-calendar:16" styleClass="meta-icon"/>
                    <Label fx:id="yearLabel" text="2024" styleClass="meta-text"/>
                  </HBox>
                  <HBox spacing="8" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="mdi2f-folder-multiple:16" styleClass="meta-icon"/>
                    <Label fx:id="seasonCountLabel" text="5 Seasons" styleClass="meta-text"/>
                  </HBox>
                  <HBox spacing="8" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="mdi2s-star-circle:16" styleClass="meta-icon rating-icon"/>
                    <Label fx:id="ratingLabel" text="4.5/5" styleClass="meta-text"/>
                  </HBox>
                  <HBox spacing="8" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="mdi2t-tag:16" styleClass="meta-icon"/>
                    <Label fx:id="genreLabel" text="Drama, Thriller" styleClass="meta-text"/>
                  </HBox>
                </HBox>

                <!-- Description -->
                <Label fx:id="descriptionLabel" styleClass="description-text" wrapText="true"
                       text="Series description goes here..."
                       maxWidth="800"/>

                <!-- Director/Country -->
                <HBox spacing="30" styleClass="credits-row">
                  <VBox spacing="3">
                    <Label text="DIRECTOR" styleClass="label-tiny"/>
                    <Label fx:id="directorLabel" text="Director Name" styleClass="credit-value"/>
                  </VBox>
                  <VBox spacing="3">
                    <Label text="COUNTRY" styleClass="label-tiny"/>
                    <Label fx:id="countryLabel" text="USA" styleClass="credit-value"/>
                  </VBox>
                </HBox>

                <!-- Action Buttons -->
                <HBox spacing="15" styleClass="hero-actions">
                  <Button fx:id="continueWatchingBtn" onAction="#continueWatching"
                          styleClass="hero-btn primary" text="Continue Watching">
                    <graphic>
                      <FontIcon iconLiteral="mdi2p-play:20"/>
                    </graphic>
                  </Button>
                  <Button fx:id="addToListBtn" onAction="#toggleFavorite"
                          styleClass="hero-btn secondary" text="My List">
                    <graphic>
                      <FontIcon iconLiteral="mdi2p-plus:18"/>
                    </graphic>
                  </Button>
                  <Button onAction="#shareSeriesUrl" styleClass="hero-btn secondary" text="Share">
                    <graphic>
                      <FontIcon iconLiteral="mdi2s-share-variant:18"/>
                    </graphic>
                  </Button>
                </HBox>
              </VBox>
            </HBox>
          </VBox>

          <!-- Continue Watching Banner (if applicable) -->
          <HBox fx:id="continueWatchingBanner" styleClass="continue-watching-banner"
                spacing="20" alignment="CENTER_LEFT" visible="false" managed="false">
            <padding>
              <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>
            <FontIcon iconLiteral="mdi2h-history:24" styleClass="banner-icon"/>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
              <Label fx:id="lastWatchedLabel" text="Continue from Season 2, Episode 3" styleClass="banner-title"/>
              <ProgressBar fx:id="episodeProgressBar" progress="0.45" styleClass="progress-bar-slim" maxWidth="200"/>
            </VBox>
            <Button onAction="#continueFromLastEpisode" styleClass="hero-btn primary" text="Resume">
              <graphic>
                <FontIcon iconLiteral="mdi2p-play:18"/>
              </graphic>
            </Button>
          </HBox>

          <!-- Season Selector Section -->
          <VBox spacing="20">
            <HBox alignment="CENTER_LEFT" spacing="15">
              <Label text="Select Season" styleClass="section-title">
                <font>
                  <Font name="Arial Bold" size="22.0"/>
                </font>
              </Label>
              <Region HBox.hgrow="ALWAYS"/>
              <ComboBox fx:id="seasonDropdown" styleClass="glass-combo" promptText="Jump to Season..." prefWidth="180"/>
            </HBox>

            <!-- Season Cards Grid -->
            <FlowPane fx:id="seasonsFlowPane" hgap="20" vgap="20"
                      styleClass="seasons-grid" alignment="TOP_LEFT"/>

            <!-- Empty State -->
            <VBox fx:id="emptyState" alignment="CENTER" spacing="20" visible="false" managed="false"
                  styleClass="empty-state">
              <padding>
                <Insets top="50" bottom="50"/>
              </padding>
              <FontIcon iconLiteral="mdi2f-folder-alert-outline:64" styleClass="empty-icon"/>
              <Label text="No Seasons Available" styleClass="empty-title"/>
              <Label text="Seasons for this series haven't been added yet." styleClass="empty-subtitle"/>
            </VBox>
          </VBox>

          <!-- Recommendations Section -->
          <VBox spacing="15" fx:id="recommendationsSection">
            <HBox alignment="CENTER_LEFT" spacing="10">
              <FontIcon iconLiteral="mdi2t-television-shimmer:24" styleClass="section-icon"/>
              <Label text="Similar Series" styleClass="section-title"/>
            </HBox>
            <ScrollPane hbarPolicy="NEVER" styleClass="scroll-pane-transparent" prefHeight="220">
              <HBox fx:id="recommendationsBox" spacing="15"/>
            </ScrollPane>
          </VBox>
        </VBox>
      </ScrollPane>
    </center>
  </BorderPane>

  <!-- Loading Overlay -->
  <VBox fx:id="loadingOverlay" styleClass="loading-overlay" alignment="CENTER" visible="false" managed="false">
    <ProgressIndicator styleClass="progress-indicator-large"/>
    <Label text="Loading series..." styleClass="loading-text"/>
  </VBox>
</StackPane>

