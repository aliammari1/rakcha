<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="520.0" prefWidth="929.0"
            stylesheets="@../styles/rakcha-unified.css" xmlns="http://javafx.com/javafx/21"
            fx:controller="com.esprit.controllers.users.VerificationCodeController">
  <children>
    <AnchorPane layoutX="467.0" prefHeight="520.0" prefWidth="468.0" styleClass="nav-form"
                stylesheets="@../styles/rakcha-unified.css">
      <children>
        <Label layoutX="31.0" layoutY="63.0" prefHeight="58.0" prefWidth="437.0"
               text="Verify Your Email" textFill="WHITE">
          <font>
            <Font name="Outfit SemiBold" size="35.0"/>
          </font>
        </Label>
        <ImageView fitHeight="325.0" fitWidth="299.0" layoutX="85.0" layoutY="134.0"
                   pickOnBounds="true" preserveRatio="true">
          <image>
            <Image url="@Logo.png"/>
          </image>
        </ImageView>
      </children>
    </AnchorPane>
    <AnchorPane prefHeight="520.0" prefWidth="461.0">
      <children>
        <Label layoutX="62.0" layoutY="53.0" text="Verify Code :">
          <font>
            <Font name="Outfit Bold" size="36.0"/>
          </font>
        </Label>
        <VBox fx:id="codeFormContainer" layoutX="88.0" layoutY="192.0" prefWidth="271.0" spacing="10"/>
        <Button fx:id="verifyButton" layoutX="88.0" layoutY="416.0" mnemonicParsing="false"
                onAction="#verifyCode" prefHeight="42.0" prefWidth="271.0" styleClass="sale"
                stylesheets="@../styles/rakcha-unified.css" text="VERIFY" textFill="WHITE">
          <font>
            <Font name="Outfit Medium" size="20.0"/>
          </font>
        </Button>
        <Label layoutX="81.0" layoutY="300.0" prefHeight="60.0" prefWidth="300.0"
               text="Enter the verification code sent to your email address."
               textFill="#cccccc" wrapText="true">
          <font>
            <Font name="Outfit Regular" size="13.0"/>
          </font>
        </Label>
        <Button layoutX="323.0" layoutY="47.0" mnemonicParsing="false" prefHeight="67.0"
                prefWidth="81.0" styleClass="sale" stylesheets="@../styles/rakcha-unified.css"/>
        <FontIcon fill="WHITE" iconLiteral="mdi2s-send" layoutX="344.0" layoutY="92.0"
                  wrappingWidth="29.0"/>
      </children>
    </AnchorPane>
  </children>
</AnchorPane>

